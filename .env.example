# --- PostgreSQL (docker-compose + local) ---
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory
POSTGRES_PORT=5432

# --- Backend ---
# Local dev (Homebrew Postgres on host):
# DATABASE_URL=postgresql://YOUR_USERNAME@localhost:5432/inventory
# Docker Compose (backend container — hostname is "db"):
# DATABASE_URL=postgresql://inventory:inventory@db:5432/inventory
DATABASE_URL=postgresql://inventory:inventory@localhost:5432/inventory
BACKEND_PORT=8000

# --- Frontend ---
# URL the browser uses to call the API (host machine ports when using Docker)
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=3000
